{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Siftlane",
  "version": "0.1.0",
  "identifier": "app.siftlane.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "Siftlane",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Lightweight and secure SFTP client",
    "longDescription": "Siftlane is a lightweight, secure SFTP client for macOS, Windows and Linux.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
