{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Minimal permissions for the Siftlane main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:allow-open-path",
    "window-state:default"
  ]
}
